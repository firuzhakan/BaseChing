# ─────────────────────────────────────────────────────────────
# BaseChing environment variables
# Copy this file to `.env.local` (for Next.js) and `.env` (for Hardhat).
# ─────────────────────────────────────────────────────────────

# ── Frontend (NEXT_PUBLIC_* is exposed to the browser) ──────────

# Coinbase Developer Platform (OnchainKit) API key.
# Get one at: https://portal.cdp.coinbase.com/
NEXT_PUBLIC_ONCHAINKIT_API_KEY=

# WalletConnect Cloud project ID (optional — improves wallet support).
# Get one at: https://cloud.walletconnect.com/
NEXT_PUBLIC_WC_PROJECT_ID=

# Target chain: 8453 = Base mainnet, 84532 = Base Sepolia testnet.
NEXT_PUBLIC_CHAIN_ID=84532

# Deployed BaseChing contract address.
# Leave blank to run the UI in "preview mode" (client-side randomness, no on-chain tx).
NEXT_PUBLIC_CONTRACT_ADDRESS=

# Public app URL (used in share links). e.g. https://baseching.xyz
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ── Contract deployment (Hardhat) ───────────────────────────────

# RPC endpoints. Public endpoints work; paid (Alchemy/Infura) are more reliable.
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Private key of the deployer wallet (NEVER commit this file).
# Use a dedicated deploy key with only enough ETH for deployment.
DEPLOYER_PRIVATE_KEY=

# Basescan API key for contract verification.
# Get one at: https://basescan.org/myapikey
BASESCAN_API_KEY=
